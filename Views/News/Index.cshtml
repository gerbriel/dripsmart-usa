@{
    ViewBag.Title = "News & Insights – Drip Smart USA";
    ViewBag.MetaDescription = "The latest drip irrigation news, grower stories, water conservation research, and precision agriculture insights from DripSmart USA.";
}

<!-- Hero -->
<section class="page-hero bg-midnight section">
    <div class="container">
        <div class="page-hero-inner">
            <div class="breadcrumb"><a href="/">Home</a> › <span>News &amp; Insights</span></div>
            <div class="page-hero-text">
                <span class="section-eyebrow">News &amp; Insights</span>
                <h1>Field Intelligence.<br>Delivered to You.</h1>
                <p>Stay ahead with the latest in drip irrigation research, grower case studies, water policy updates, and precision agriculture technology from the DripSmart team.</p>
                <div class="hero-actions">
                    <a href="#newsletter" class="btn-primary btn-lg">Subscribe to Updates</a>
                    <a href="#articles" class="btn-ghost">Browse Articles</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Featured Article -->
<section class="section bg-cream">
    <div class="container">
        <span class="section-eyebrow">Featured Story</span>
        <div class="two-col-layout" style="margin-top:24px;align-items:stretch;">
            <div style="background:var(--midnight);border-radius:16px;overflow:hidden;min-height:360px;display:flex;align-items:flex-end;background:linear-gradient(160deg,#181F4E 60%,#3B98FF 140%);position:relative;">
                <div style="padding:36px;">
                    <span style="background:var(--mustard);color:var(--midnight);font-size:0.72rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:4px 12px;border-radius:20px;">Water Conservation</span>
                    <h2 style="color:var(--white);margin-top:16px;font-size:clamp(1.3rem,2.5vw,1.9rem);">California Almond Growers Cut Water Use by 43% with Subsurface Drip</h2>
                    <p style="color:var(--blue-light);margin-top:10px;">A coalition of 38 Kern County almond growers partnered with DripSmart to install SDI across 9,200 acres — and the results are reshaping how the region thinks about water stewardship.</p>
                    <a href="/growers-stories" class="btn-primary" style="margin-top:20px;display:inline-block;">Read the Full Story →</a>
                </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:20px;">
                <div class="news-card" style="flex:1;">
                    <span class="news-tag">Policy Update</span>
                    <h4><a href="#">USDA Adds Drip Irrigation to EQIP Priority Practices for 2025</a></h4>
                    <p>New federal guidance expands payment rates for subsurface and surface drip systems under USDA's EQIP program — effective October 1, 2025.</p>
                    <div class="news-card-footer"><time>July 14, 2025</time><a class="news-read-more" href="#">Read more →</a></div>
                </div>
                <div class="news-card" style="flex:1;">
                    <span class="news-tag">Research</span>
                    <h4><a href="#">Study: Drip-Fertigation Reduces Nitrogen Runoff by 61%</a></h4>
                    <p>UC Davis researchers confirm that precise fertigation through drip systems dramatically reduces nutrient loss compared to broadcast application.</p>
                    <div class="news-card-footer"><time>June 28, 2025</time><a class="news-read-more" href="#">Read more →</a></div>
                </div>
                <div class="news-card" style="flex:1;">
                    <span class="news-tag">Technology</span>
                    <h4><a href="#">DripSphere OS 4.0 Launches with AI-Powered Soil Moisture Forecasting</a></h4>
                    <p>Our next-generation irrigation management platform now integrates machine learning predictions with real-time field sensor data.</p>
                    <div class="news-card-footer"><time>June 10, 2025</time><a class="news-read-more" href="#">Read more →</a></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Filter Bar -->
<section class="section" id="articles">
    <div class="container">
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:40px;">
            <button style="background:var(--midnight);color:var(--white);border:none;padding:8px 20px;border-radius:20px;font-weight:600;cursor:pointer;">All</button>
            <button style="background:transparent;color:var(--text-muted);border:1.5px solid var(--border);padding:8px 20px;border-radius:20px;font-weight:500;cursor:pointer;">Grower Stories</button>
            <button style="background:transparent;color:var(--text-muted);border:1.5px solid var(--border);padding:8px 20px;border-radius:20px;font-weight:500;cursor:pointer;">Water Conservation</button>
            <button style="background:transparent;color:var(--text-muted);border:1.5px solid var(--border);padding:8px 20px;border-radius:20px;font-weight:500;cursor:pointer;">Technology</button>
            <button style="background:transparent;color:var(--text-muted);border:1.5px solid var(--border);padding:8px 20px;border-radius:20px;font-weight:500;cursor:pointer;">Policy &amp; Incentives</button>
            <button style="background:transparent;color:var(--text-muted);border:1.5px solid var(--border);padding:8px 20px;border-radius:20px;font-weight:500;cursor:pointer;">Research</button>
            <button style="background:transparent;color:var(--text-muted);border:1.5px solid var(--border);padding:8px 20px;border-radius:20px;font-weight:500;cursor:pointer;">Company News</button>
        </div>

        <div class="news-grid">
            <div class="news-card">
                <div class="news-card-img" style="background:linear-gradient(135deg,#181F4E,#3B98FF);">🌽</div>
                <div style="padding:20px;">
                    <span class="news-tag">Grower Stories</span>
                    <h4><a href="/growers-stories">Iowa Corn Grower Converts 2,400 Acres to SDI — And Cuts Input Costs by 28%</a></h4>
                    <p>Fifth-generation farmer Randy Kohl shares how subsurface drip changed his relationship with inputs, yield, and weather risk.</p>
                    <div class="news-card-footer"><time>July 2, 2025</time><a class="news-read-more" href="/growers-stories">Read more →</a></div>
                </div>
            </div>
            <div class="news-card">
                <div class="news-card-img" style="background:linear-gradient(135deg,#181F4E,#3B98FF);">🍓</div>
                <div style="padding:20px;">
                    <span class="news-tag">Grower Stories</span>
                    <h4><a href="/growers-stories">Oxnard Strawberry Farm Cuts Disease Pressure 55% After Switch to Drip</a></h4>
                    <p>Keeping foliage dry eliminated their biggest fungal disease challenge while improving uniformity across 480 acres of Class 1 berries.</p>
                    <div class="news-card-footer"><time>June 22, 2025</time><a class="news-read-more" href="/growers-stories">Read more →</a></div>
                </div>
            </div>
            <div class="news-card">
                <div class="news-card-img" style="background:linear-gradient(135deg,#3B98FF,#89C1FF);">💧</div>
                <div style="padding:20px;">
                    <span class="news-tag">Water Conservation</span>
                    <h4><a href="#">Arizona Water District Reports Record Conservation from Drip Incentive Program</a></h4>
                    <p>The Salt River Project's subsurface drip conversion incentive produced 42,000 acre-feet of water savings in its first full year.</p>
                    <div class="news-card-footer"><time>June 15, 2025</time><a class="news-read-more" href="#">Read more →</a></div>
                </div>
            </div>
            <div class="news-card">
                <div class="news-card-img" style="background:linear-gradient(135deg,#FFBC03,#EF6C00);">⚙️</div>
                <div style="padding:20px;">
                    <span class="news-tag">Technology</span>
                    <h4><a href="/digital-farming">How AI-Driven Irrigation Schedules Are Changing Deficit Irrigation Strategy</a></h4>
                    <p>The DripSphere OS platform's ML scheduling engine is allowing growers to optimize regulated deficit irrigation with accuracy never before possible.</p>
                    <div class="news-card-footer"><time>June 5, 2025</time><a class="news-read-more" href="/digital-farming">Read more →</a></div>
                </div>
            </div>
            <div class="news-card">
                <div class="news-card-img" style="background:linear-gradient(135deg,#592724,#C34121);">🏛️</div>
                <div style="padding:20px;">
                    <span class="news-tag">Policy &amp; Incentives</span>
                    <h4><a href="#">2025 Farm Bill Provisions for Irrigation: What Growers Need to Know Now</a></h4>
                    <p>A complete breakdown of how the 2025 Farm Bill affects irrigation financing, EQIP rates, and conservation compliance requirements.</p>
                    <div class="news-card-footer"><time>May 30, 2025</time><a class="news-read-more" href="#">Read more →</a></div>
                </div>
            </div>
            <div class="news-card">
                <div class="news-card-img" style="background:linear-gradient(135deg,#181F4E,#89C1FF);">🔬</div>
                <div style="padding:20px;">
                    <span class="news-tag">Research</span>
                    <h4><a href="#">New Emitter Technology Extends System Life to 30+ Years in Sandy Soils</a></h4>
                    <p>DripSmart Engineering's new DuraRoot emitter passes 30-year lifecycle testing, reducing total system cost of ownership dramatically.</p>
                    <div class="news-card-footer"><time>May 18, 2025</time><a class="news-read-more" href="#">Read more →</a></div>
                </div>
            </div>
        </div>

        <div style="text-align:center;margin-top:48px;">
            <a href="#" class="btn-outline">Load More Articles</a>
        </div>
    </div>
</section>

<!-- Newsletter -->
<section class="section bg-blue-pale" id="newsletter">
    <div class="container">
        <div style="max-width:600px;margin:0 auto;text-align:center;">
            <span class="section-eyebrow">Newsletter</span>
            <h2>Stay Ahead of the Field</h2>
            <p>Join 18,000+ growers, agronomists, and water managers who get the DripSmart Digest — monthly insights, research summaries, and incentive alerts.</p>
            <div style="display:flex;gap:12px;margin-top:32px;flex-wrap:wrap;justify-content:center;">
                <input type="email" placeholder="Enter your email address" style="flex:1;min-width:260px;padding:14px 18px;border:1.5px solid var(--border);border-radius:8px;font-size:1rem;font-family:inherit;" />
                <button class="btn-primary">Subscribe Free</button>
            </div>
            <p style="font-size:0.78rem;color:var(--text-muted);margin-top:12px;">No spam. Unsubscribe anytime. Read our <a href="#" style="color:var(--blue);">Privacy Policy</a>.</p>
        </div>
    </div>
</section>

<!-- CTA -->
<div class="callout-band">
    <div class="container">
        <h2>Have a Story to Share?</h2>
        <p>We'd love to feature your operation. DripSmart grower stories inspire thousands of farmers to make the switch each year.</p>
        <a href="/contact" class="btn-white">Submit Your Story</a>
    </div>
</div>
