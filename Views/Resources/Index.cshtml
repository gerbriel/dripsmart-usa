@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Resources & Tools – Drip Smart USA";
}

<section class="page-hero" style="background: linear-gradient(135deg, #0e1438 0%, #181F4E 100%);">
    <div class="container page-hero-inner">
        <div class="page-hero-text">
            <nav class="breadcrumb"><a href="/">Home</a> / <span>Resources</span></nav>
            <h1>Tools &amp; Knowledge<br/>for Smarter Growing</h1>
            <p>Free tools, guides, courses, and calculators to help you design, optimize, and master your irrigation system.</p>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-header centered">
            <span class="section-eyebrow">Free Resources</span>
            <h2>Everything You Need to Grow Smarter</h2>
        </div>
        <div class="resources-grid" style="grid-template-columns: repeat(3, 1fr);">
            <a href="/agriculture/irrigation-academy" class="resource-card">
                <div class="resource-icon">🎓</div>
                <h4>Irrigation Academy</h4>
                <p>Free online courses, how-tos, and expert guides to master precision irrigation at your own pace.</p>
                <span class="resource-tag">Free Learning</span>
            </a>
            <a href="/resources/hydrocalc" class="resource-card">
                <div class="resource-icon">🧮</div>
                <h4>HydroCalc 3.0</h4>
                <p>Design your drip system right — our free hydraulic calculation tool handles the engineering math for you.</p>
                <span class="resource-tag">Free Tool</span>
            </a>
            <a href="/resources/cad-details" class="resource-card">
                <div class="resource-icon">📐</div>
                <h4>CAD Details</h4>
                <p>Download CAD drawings and system schematics for use in your field planning and permit applications.</p>
                <span class="resource-tag">Downloads</span>
            </a>
            <a href="/financial-solutions" class="resource-card">
                <div class="resource-icon">💰</div>
                <h4>Financing Options</h4>
                <p>Flexible payment plans and financing programs to help you invest without straining cash flow.</p>
                <span class="resource-tag">Financing</span>
            </a>
            <a href="/resources/equipment-guide" class="resource-card">
                <div class="resource-icon">📋</div>
                <h4>Equipment Selection Guide</h4>
                <p>Not sure which dripline or emitter is right for your crop? Our quick guide walks you through it.</p>
                <span class="resource-tag">Guide</span>
            </a>
            <a href="/blog" class="resource-card">
                <div class="resource-icon">📰</div>
                <h4>Blog &amp; News</h4>
                <p>Stay current on irrigation technology, crop science, sustainability trends, and company news.</p>
                <span class="resource-tag">Content</span>
            </a>
        </div>
    </div>
</section>
