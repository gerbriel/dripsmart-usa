@{
    ViewBag.Title = "Greenhouse & Nursery Irrigation – Drip Smart USA";
    ViewBag.MetaDescription = "Precision drip and misting solutions for commercial greenhouses, nurseries, and indoor growing operations. Maximize yield, minimize inputs.";
}

<!-- Hero -->
<section class="page-hero bg-midnight section">
    <div class="container">
        <div class="page-hero-inner">
            <div class="breadcrumb"><a href="/">Home</a> › <a href="/industries">Industries</a> › <span>Greenhouse &amp; Nursery</span></div>
            <div class="page-hero-text">
                <span class="section-eyebrow">Greenhouse &amp; Nursery</span>
                <h1>Precision Growing.<br>From Seed to Sale.</h1>
                <p>Whether you manage a 10,000 sq/ft greenhouse or a 200-acre nursery operation, our precision watering systems deliver consistent, repeatable results that drive yield and quality.</p>
                <div class="hero-actions">
                    <a href="/contact" class="btn-primary btn-lg">Get a Greenhouse Quote</a>
                    <a href="/find-a-dealer" class="btn-ghost">Find a Dealer</a>
                </div>
            </div>
        </div>
        <div class="crop-hero-stats">
            <div class="crop-stat"><span class="crop-stat-num">40%</span><span class="crop-stat-label">Water Reduction</span></div>
            <div class="crop-stat"><span class="crop-stat-num">2×</span><span class="crop-stat-label">Crop Cycles Per Year</span></div>
            <div class="crop-stat"><span class="crop-stat-num">99%</span><span class="crop-stat-label">Fertigation Accuracy</span></div>
            <div class="crop-stat"><span class="crop-stat-num">500+</span><span class="crop-stat-label">Greenhouse Clients</span></div>
        </div>
    </div>
</section>

<!-- Solutions -->
<section class="section bg-cream">
    <div class="container">
        <div class="section-header centered">
            <span class="section-eyebrow">Solutions</span>
            <h2>The Complete Greenhouse Water System</h2>
            <p>From irrigation to fertigation to climate control — DripSmart components work together so your crops thrive automatically.</p>
        </div>
        <div class="three-col-grid">
            <div class="info-card">
                <div class="info-card-icon" style="color: var(--orange)">🪴</div>
                <h3>Pot &amp; Container Irrigation</h3>
                <p>Individual drip stakes, adjustable emitters, and spaghetti tubing deliver precise amounts to each container — no over or under watering.</p>
                <ul class="check-list">
                    <li>Adjustable 0–80 L/hr emitters</li>
                    <li>Color-coded flow rates</li>
                    <li>Anti-siphon design</li>
                </ul>
            </div>
            <div class="info-card">
                <div class="info-card-icon" style="color: var(--blue)">🌫️</div>
                <h3>Misting &amp; Humidification</h3>
                <p>High-pressure misting systems for cuttings, propagation houses, and tropical species. Maintain ideal humidity without wetting foliage excessively.</p>
                <ul class="check-list">
                    <li>50–70 micron droplet size</li>
                    <li>Fog nozzles and misters</li>
                    <li>Humidity sensor integration</li>
                </ul>
            </div>
            <div class="info-card">
                <div class="info-card-icon" style="color: var(--green-01)">🧪</div>
                <h3>Precision Fertigation</h3>
                <p>Inject liquid fertilizers, pH adjusters, and pesticides directly into irrigation lines with our DripSphere OS™ fertigation units — at exactly the right dose, every time.</p>
                <ul class="check-list">
                    <li>±1% dosing accuracy</li>
                    <li>Multi-channel injection</li>
                    <li>EC &amp; pH inline monitoring</li>
                </ul>
            </div>
            <div class="info-card">
                <div class="info-card-icon" style="color: var(--mustard)">🏗️</div>
                <h3>Gutter &amp; Trough Systems</h3>
                <p>Recirculating NFT and Dutch Trough systems for cut flowers, tomatoes, cucumbers, and lettuce. Closed-loop for zero water waste.</p>
                <ul class="check-list">
                    <li>Recirculating gutter design</li>
                    <li>Compatible with Rockwool &amp; peat</li>
                    <li>Automatic drainage</li>
                </ul>
            </div>
            <div class="info-card">
                <div class="info-card-icon">🌿</div>
                <h3>Nursery Overhead &amp; Boom</h3>
                <p>Overhead sprinklers and automated traveling boom irrigators for nursery stock, seedlings, and transplants grown in outdoor shade houses.</p>
                <ul class="check-list">
                    <li>Uniform distribution coefficient</li>
                    <li>Variable speed travel booms</li>
                    <li>Nozzle options for all media types</li>
                </ul>
            </div>
            <div class="highlight-card">
                <div class="info-card-icon">📊</div>
                <h3>Climate &amp; Irrigation Control</h3>
                <p>Integrate irrigation with climate sensors, shading, and heating through the DripSphere OS™ Greenhouse Edition — one dashboard for your entire operation.</p>
                <a href="/digital-farming" class="btn-outline-dark mt-md">Explore DripSphere OS™</a>
            </div>
        </div>
    </div>
</section>

<!-- Stats -->
<section class="section" style="padding:0;">
    <div class="container">
        <div class="stat-strip">
            <div class="stat-strip-item"><span class="stat-strip-num">40%</span><span class="stat-strip-label">Less Water Usage</span></div>
            <div class="stat-strip-item"><span class="stat-strip-num">±1%</span><span class="stat-strip-label">Fertigation Accuracy</span></div>
            <div class="stat-strip-item"><span class="stat-strip-num">2×</span><span class="stat-strip-label">Crop Cycles Possible</span></div>
            <div class="stat-strip-item"><span class="stat-strip-num">Zero</span><span class="stat-strip-label">Nutrient Runoff Loss</span></div>
        </div>
    </div>
</section>

<!-- Two col feature -->
<section class="section">
    <div class="container">
        <div class="two-col-layout">
            <div>
                <span class="section-eyebrow">DripSphere OS™ Greenhouse Edition</span>
                <h2>Your Greenhouse on Autopilot</h2>
                <p>Set growing recipes — temperature ranges, irrigation schedules, and fertilizer programs — and let DripSphere OS™ run them automatically. Monitor every bench in real time from your phone.</p>
                <ul class="check-list" style="margin-top:20px;">
                    <li>Automated irrigation by time, volume, or sensor trigger</li>
                    <li>Inline EC and pH monitoring with auto-adjust</li>
                    <li>Crop-specific growing programs library</li>
                    <li>Alert notifications for pump failures, leaks, or pH drift</li>
                    <li>Historical data and yield tracking dashboard</li>
                </ul>
                <a href="/digital-farming" class="btn-primary mt-lg">Explore DripSphere OS™</a>
            </div>
            <div style="background: var(--midnight); border-radius: var(--radius-lg); padding: 40px; display: flex; flex-direction: column; gap: 20px;">
                <div style="background: rgba(59,152,255,0.12); border: 1px solid rgba(59,152,255,0.25); border-radius: 12px; padding: 20px; color: white;">
                    <div style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; opacity: 0.6; margin-bottom: 8px;">DripSphere OS™ Live</div>
                    <div style="font-size: 1rem; font-weight: 700; color: #89C1FF; margin-bottom: 4px;">Zone A — Propagation House</div>
                    <div style="font-size: 0.85rem; opacity: 0.7;">EC: 1.8 mS/cm &nbsp;|&nbsp; pH: 5.9 &nbsp;|&nbsp; Temp: 72°F</div>
                    <div style="margin-top: 12px; height: 6px; background: rgba(255,255,255,0.1); border-radius: 99px;"><div style="width: 72%; height: 100%; background: #3B98FF; border-radius: 99px;"></div></div>
                    <div style="font-size: 0.78rem; opacity: 0.55; margin-top: 6px;">Irrigation cycle: 72% complete</div>
                </div>
                <div style="background: rgba(255,188,3,0.1); border: 1px solid rgba(255,188,3,0.2); border-radius: 12px; padding: 20px; color: white;">
                    <div style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; opacity: 0.6; margin-bottom: 8px;">Alert</div>
                    <div style="font-size: 0.9rem; font-weight: 600; color: #FFBC03;">Zone C pH Rising — 6.4</div>
                    <div style="font-size: 0.83rem; opacity: 0.7; margin-top: 4px;">Auto-correction triggered. Injecting pH Down solution.</div>
                </div>
                <div style="background: rgba(150,204,47,0.1); border: 1px solid rgba(150,204,47,0.2); border-radius: 12px; padding: 20px; color: white;">
                    <div style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; opacity: 0.6; margin-bottom: 8px;">Today's Summary</div>
                    <div style="display: flex; gap: 20px; margin-top: 8px;">
                        <div><div style="font-size: 1.4rem; font-weight: 800; color: #96CC2F;">47L</div><div style="font-size: 0.72rem; opacity: 0.65;">Water Used</div></div>
                        <div><div style="font-size: 1.4rem; font-weight: 800; color: #96CC2F;">12g</div><div style="font-size: 0.72rem; opacity: 0.65;">Nutrients Dosed</div></div>
                        <div><div style="font-size: 1.4rem; font-weight: 800; color: #96CC2F;">4</div><div style="font-size: 0.72rem; opacity: 0.65;">Cycles Completed</div></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<div class="callout-mustard">
    <div class="container">
        <h2>Grow More. Waste Less.</h2>
        <p>Our greenhouse irrigation specialists will design a complete system — including fertigation, controls, and installation support — tailored to your crops and structure.</p>
        <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
            <a href="/contact" class="btn-primary">Request a System Design</a>
            <a href="/find-a-dealer" class="btn-outline-dark">Find a Local Installer</a>
