@{
    ViewBag.Title = "Landscape & Turf Irrigation – Drip Smart USA";
    ViewBag.MetaDescription = "Precision irrigation solutions for landscape architects, golf courses, sports turf, and commercial properties. Conserve water, protect your investment.";
}

<!-- Hero -->
<section class="page-hero bg-midnight section">
    <div class="container">
        <div class="page-hero-inner">
            <div class="breadcrumb"><a href="/">Home</a> › <a href="/industries">Industries</a> › <span>Landscape &amp; Turf</span></div>
            <div class="page-hero-text">
                <span class="section-eyebrow">Landscape &amp; Turf</span>
                <h1>Greener Spaces.<br>Smarter Water Use.</h1>
                <p>From golf course fairways to commercial campuses and residential estates — our precision drip and micro-irrigation systems keep landscapes lush while cutting water use by up to 50%.</p>
                <div class="hero-actions">
                    <a href="/contact" class="btn-primary btn-lg">Get a Landscape Quote</a>
                    <a href="/find-a-dealer" class="btn-ghost">Find a Dealer</a>
                </div>
            </div>
        </div>
        <div class="crop-hero-stats">
            <div class="crop-stat"><span class="crop-stat-num">50%</span><span class="crop-stat-label">Average Water Savings</span></div>
            <div class="crop-stat"><span class="crop-stat-num">25K+</span><span class="crop-stat-label">Landscapes Installed</span></div>
            <div class="crop-stat"><span class="crop-stat-num">99%</span><span class="crop-stat-label">Uniformity Rating</span></div>
            <div class="crop-stat"><span class="crop-stat-num">15yr</span><span class="crop-stat-label">System Lifespan</span></div>
        </div>
    </div>
</section>

<!-- Applications -->
<section class="section bg-cream">
    <div class="container">
        <div class="section-header centered">
            <span class="section-eyebrow">Applications</span>
            <h2>Irrigation for Every Landscape</h2>
            <p>Whether you manage a municipal park or a private estate, we have a system engineered for your specific environment.</p>
        </div>
        <div class="three-col-grid">
            <div class="info-card">
                <div class="info-card-icon">⛳</div>
                <h3>Golf Courses</h3>
                <p>Precision fairway and green irrigation that maximizes playability and minimizes water bills. Smart sensors auto-adjust for weather and soil moisture in real time.</p>
                <ul class="check-list">
                    <li>Fairway drip systems</li>
                    <li>Greens micro-spray</li>
                    <li>Automated weather-based scheduling</li>
                    <li>USGA certified products</li>
                </ul>
            </div>
            <div class="info-card">
                <div class="info-card-icon">🏟️</div>
                <h3>Sports Turf</h3>
                <p>Sub-surface drip irrigation delivers water directly to the root zone for fast-growing, resilient playing surfaces — with no wet spots or muddy sidelines.</p>
                <ul class="check-list">
                    <li>Sub-surface drip tubing</li>
                    <li>Even moisture distribution</li>
                    <li>Reduced compaction risk</li>
                    <li>Compatible with synthetic turf cooling</li>
                </ul>
            </div>
            <div class="info-card">
                <div class="info-card-icon">🏢</div>
                <h3>Commercial Properties</h3>
                <p>Corporate campuses, HOA communities, and retail properties benefit from automated, low-maintenance drip systems that stay invisible while keeping grounds beautiful.</p>
                <ul class="check-list">
                    <li>Low-profile dripline installation</li>
                    <li>Centralized zone controls</li>
                    <li>LEED certification compatible</li>
                    <li>24/7 remote monitoring</li>
                </ul>
            </div>
            <div class="info-card">
                <div class="info-card-icon">🌳</div>
                <h3>Trees &amp; Shrubs</h3>
                <p>Deep root watering bubblers and ring emitters provide slow, targeted delivery that encourages deep root establishment and drought tolerance.</p>
                <ul class="check-list">
                    <li>Tree bubblers and root feeders</li>
                    <li>Pressure-compensating emitters</li>
                    <li>Suitable for slopes and terraces</li>
                </ul>
            </div>
            <div class="info-card">
                <div class="info-card-icon">🌺</div>
                <h3>Garden Beds &amp; Borders</h3>
                <p>Micro-drip and soaker systems for ornamental plantings, raised beds, and seasonal gardens. Reduces fungal disease by keeping foliage dry.</p>
                <ul class="check-list">
                    <li>In-line and on-line drippers</li>
                    <li>Adjustable flow emitters</li>
                    <li>Weed suppression effect</li>
                </ul>
            </div>
            <div class="highlight-card">
                <div class="info-card-icon">💡</div>
                <h3>DripSphere OS™ Smart Control</h3>
                <p>Pair any landscape system with our DripSphere OS™ controller. Schedule, monitor, and optimize every zone from your smartphone — with automatic rain shutoff included.</p>
                <a href="/digital-farming" class="btn-outline-dark mt-md">Explore DripSphere OS™</a>
            </div>
        </div>
    </div>
</section>

<!-- Stats strip -->
<section class="section" style="padding: 0;">
    <div class="container">
        <div class="stat-strip">
            <div class="stat-strip-item"><span class="stat-strip-num">50%</span><span class="stat-strip-label">Less Water Than Spray</span></div>
            <div class="stat-strip-item"><span class="stat-strip-num">90%</span><span class="stat-strip-label">Irrigation Efficiency</span></div>
            <div class="stat-strip-item"><span class="stat-strip-num">$0</span><span class="stat-strip-label">Wet Foliage &amp; Disease</span></div>
            <div class="stat-strip-item"><span class="stat-strip-num">24/7</span><span class="stat-strip-label">Smart Monitoring</span></div>
        </div>
    </div>
</section>

<!-- Products -->
<section class="section">
    <div class="container">
        <div class="section-header">
            <div>
                <span class="section-eyebrow">Products</span>
                <h2>Purpose-Built Landscape Products</h2>
            </div>
            <a href="/resources" class="btn-outline">View Catalog</a>
        </div>
        <div class="three-col-grid">
            <div class="product-card">
                <div class="product-card-icon">🟦</div>
                <span class="product-tag">Drip</span>
                <h3>TopDrip™ Landscape Line</h3>
                <p>Brown or green dripline engineered for landscape beds with built-in root intrusion barrier and 15-year product warranty.</p>
                <a href="/resources" class="btn-primary-sm">Learn More →</a>
            </div>
            <div class="product-card">
                <div class="product-card-icon">💦</div>
                <span class="product-tag">Micro-Spray</span>
                <h3>SpinNet™ Micro-Sprayers</h3>
                <p>Adjustable arc micro-sprays for groundcover and dense planting areas. Available in 90°, 180°, and 360° coverage patterns.</p>
                <a href="/resources" class="btn-primary-sm">Learn More →</a>
            </div>
            <div class="product-card">
                <div class="product-card-icon">🧠</div>
                <span class="product-tag">Smart Control</span>
                <h3>DripSphere OS™ LC Controller</h3>
                <p>Landscape-specific controller with Wi-Fi, 16 zones, and EPA WaterSense certification. Pays for itself in water savings.</p>
                <a href="/digital-farming" class="btn-primary-sm">Learn More →</a>
            </div>
            <div class="product-card">
                <div class="product-card-icon">🌊</div>
                <span class="product-tag">Subsurface</span>
                <h3>SubTurf™ SDI System</h3>
                <p>Sub-surface drip irrigation designed for sports fields and high-traffic areas. Invisible, efficient, and virtually maintenance-free.</p>
                <a href="/resources" class="btn-primary-sm">Learn More →</a>
            </div>
            <div class="product-card">
                <div class="product-card-icon">🔩</div>
                <span class="product-tag">Fittings</span>
                <h3>FlexFit™ Connectors</h3>
                <p>UV-resistant barbed, threaded, and push-fit connectors compatible with all DripSmart tubing and standard landscape pipe.</p>
                <a href="/resources" class="btn-primary-sm">Learn More →</a>
            </div>
            <div class="product-card">
                <div class="product-card-icon">🔽</div>
                <span class="product-tag">Pressure Regulation</span>
                <h3>AquaReg™ Pressure Regulators</h3>
                <p>Inline pressure regulators that protect emitters on high-pressure municipal supply lines. Essential for long-lasting performance.</p>
                <a href="/resources" class="btn-primary-sm">Learn More →</a>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<div class="callout-band">
    <div class="container">
        <h2>Start Your Landscape Irrigation Project</h2>
        <p>Get a customized system design and quote from a DripSmart Certified Landscape Installer near you.</p>
        <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
            <a href="/contact" class="btn-white">Request a Free Design</a>
            <a href="/find-a-dealer" class="btn-outline-white">Find an Installer</a>
        </div>
    </div>
</div>
