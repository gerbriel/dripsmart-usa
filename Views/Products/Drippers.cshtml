@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "On-Line Drippers – Drip Smart USA";
    ViewBag.MetaDescription = "DripSmart on-line drippers for trees, containers, nurseries, and landscape applications. Adjustable and pressure-compensating models.";
}

<section class="page-hero" style="background: linear-gradient(135deg, #181F4E 0%, #1e2d6e 100%);">
    <div class="container page-hero-inner">
        <div class="page-hero-text">
            <nav class="breadcrumb"><a href="/">Home</a> / <a href="/products">Products</a> / <span>On-Line Drippers</span></nav>
            <h1>On-Line Drippers</h1>
            <p>Individual emitters punched directly into supply tubing — delivering precise, low-volume water to each plant independently. The go-to solution for trees, containers, and mixed-spacing applications.</p>
            <a href="/find-a-dealer" class="btn-primary" style="margin-top:24px;">Find a Local Dealer</a>
        </div>
    </div>
</section>

<!-- Applications -->
<section class="section">
    <div class="container">
        <div class="section-header centered">
            <span class="section-eyebrow">Applications</span>
            <h2>Where On-Line Drippers Excel</h2>
        </div>
        <div class="three-col-grid" style="margin-top:40px;">
            <div class="info-card">
                <div class="info-card-icon">🌳</div>
                <h3>Orchards & Vineyards</h3>
                <p>Individual drippers placed at each tree or vine deliver consistent water right at the rootball — ideal where trees are irregularly spaced or on non-uniform terrain.</p>
            </div>
            <div class="info-card">
                <div class="info-card-icon">🪴</div>
                <h3>Container & Nursery</h3>
                <p>Arrow drippers inserted directly into pots provide uniform irrigation across greenhouse and nursery benches — configurable for any pot size and plant type.</p>
            </div>
            <div class="info-card">
                <div class="info-card-icon">🏡</div>
                <h3>Landscape & Residential</h3>
                <p>Retrofit any existing tubing system with individual drippers for shrubs, trees, and raised beds. Adjustable models let you tune flow to each plant's needs.</p>
            </div>
        </div>
    </div>
</section>

<!-- Product Lines -->
<section class="section" style="background:var(--blue-pale);">
    <div class="container">
        <div class="section-header centered">
            <span class="section-eyebrow">Product Lines</span>
            <h2>Dripper Configurations</h2>
        </div>
        <div class="two-col-layout" style="margin-top:40px; gap:24px;">
            <div class="info-card">
                <div class="info-card-icon">💧</div>
                <h3>DS-Dripper™ Adjustable</h3>
                <p>Rotating turret allows field adjustment from 0 to 20 GPH. Snap-in barb connection to 1/2" and 3/4" poly tubing. Clog-resistant turbulent flow path.</p>
                <ul class="check-list" style="margin-top:12px;">
                    <li>0–20 GPH adjustable range</li>
                    <li>Barb or stake configurations</li>
                    <li>UV-stabilized polypropylene</li>
                    <li>Available in bulk bags (100/500 count)</li>
                </ul>
            </div>
            <div class="info-card">
                <div class="info-card-icon">💧</div>
                <h3>DS-Dripper PC™ Pressure Compensating</h3>
                <p>Delivers a fixed, precise flow rate regardless of pressure variation from 7–45 PSI. Essential for long runs, slopes, or systems with pressure fluctuations.</p>
                <ul class="check-list" style="margin-top:12px;">
                    <li>0.5, 1.0, 2.0, 4.0 GPH preset rates</li>
                    <li>Color-coded by flow rate</li>
                    <li>Self-flushing mechanism</li>
                    <li>Compatible with DS-Stakes and DS-Arrows</li>
                </ul>
            </div>
            <div class="info-card">
                <div class="info-card-icon">🏹</div>
                <h3>DS-Arrow™ Stakes</h3>
                <p>Inserted directly into containers and ground soil — secure, upright positioning keeps emitters from being dislodged during cultivation or wind events.</p>
                <ul class="check-list" style="margin-top:12px;">
                    <li>6", 8", and 12" stake heights</li>
                    <li>360° distributing heads available</li>
                    <li>Weighted bases for container use</li>
                </ul>
            </div>
            <div class="info-card">
                <div class="info-card-icon">🔗</div>
                <h3>DS-Micro Tubing</h3>
                <p>1/4" distribution tubing connecting supply lines to individual emitters. Flexible, kink-resistant, and UV-stabilized for above-ground runs up to 3 ft.</p>
                <ul class="check-list" style="margin-top:12px;">
                    <li>Sold in 100 ft and 250 ft rolls</li>
                    <li>Barbed connectors included</li>
                    <li>Rated to 45 PSI working pressure</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="section" style="background:var(--midnight); color:white;">
    <div class="container text-center">
        <h2 style="color:white;">Available Through Your Local DripSmart Dealer</h2>
        <p style="color:rgba(255,255,255,0.75); max-width:520px; margin:16px auto 0;">Drippers, stakes, and micro tubing are stocked by DripSmart dealers nationwide. Find your nearest dealer for local availability and pricing.</p>
        <a href="/find-a-dealer" class="btn-primary" style="margin-top:28px; display:inline-block;">Find a Dealer Near You</a>
    </div>
</section>
