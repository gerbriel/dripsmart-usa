@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Products – Drip Smart USA";
    ViewBag.MetaDescription = "Browse DripSmart's full line of drip irrigation products — driplines, sprinklers, filters, drippers, connectors, and digital farming technology.";
}

<section class="page-hero" style="background: linear-gradient(135deg, #181F4E 0%, #1e2d6e 100%);">
    <div class="container page-hero-inner">
        <div class="page-hero-text">
            <nav class="breadcrumb"><a href="/">Home</a> / <span>Products</span></nav>
            <h1>Precision Irrigation Products Built to Last</h1>
            <p>Every DripSmart component is engineered for field performance — designed to work as a system, sold through dealers who know how to put it together right.</p>
        </div>
    </div>
</section>

<!-- Product Categories -->
<section class="section">
    <div class="container">
        <div class="section-header centered">
            <span class="section-eyebrow">Product Lines</span>
            <h2>Everything From the Emitter to the App</h2>
        </div>
        <div class="three-col-grid" style="margin-top:40px;">
            <a href="/products/driplines" class="info-card" style="text-decoration:none; color:inherit; display:block; transition:transform 0.2s;">
                <div class="info-card-icon">〰️</div>
                <h3>Driplines & Drip Tape</h3>
                <p>From single-season drip tape for row crops to 20-year subsurface driplines for permanent orchards — the foundation of every drip system.</p>
                <span style="color:var(--blue); font-weight:600; margin-top:12px; display:inline-block;">View Products →</span>
            </a>
            <a href="/products/sprinklers" class="info-card" style="text-decoration:none; color:inherit; display:block;">
                <div class="info-card-icon">🌀</div>
                <h3>Sprinklers & Micro-Sprinklers</h3>
                <p>Low-volume micro-sprinklers and full-coverage sprinklers for frost protection, germination, and canopy applications where drip isn't optimal.</p>
                <span style="color:var(--blue); font-weight:600; margin-top:12px; display:inline-block;">View Products →</span>
            </a>
            <a href="/products/filters" class="info-card" style="text-decoration:none; color:inherit; display:block;">
                <div class="info-card-icon">🔩</div>
                <h3>Filters & Valves</h3>
                <p>Screen, disc, and sand media filters — plus pressure regulators, air release valves, and flush valves — to keep your system running clean.</p>
                <span style="color:var(--blue); font-weight:600; margin-top:12px; display:inline-block;">View Products →</span>
            </a>
            <a href="/products/drippers" class="info-card" style="text-decoration:none; color:inherit; display:block;">
                <div class="info-card-icon">💧</div>
                <h3>On-Line Drippers</h3>
                <p>Individual drippers for trees, containers, and nursery applications. Available in adjustable and pressure-compensating models with multiple stake configurations.</p>
                <span style="color:var(--blue); font-weight:600; margin-top:12px; display:inline-block;">View Products →</span>
            </a>
            <a href="/products/connectors" class="info-card" style="text-decoration:none; color:inherit; display:block;">
                <div class="info-card-icon">🔗</div>
                <h3>Connectors & Accessories</h3>
                <p>Barbed fittings, compression connectors, end caps, goof plugs, stakes, and the full range of accessories that complete every installation.</p>
                <span style="color:var(--blue); font-weight:600; margin-top:12px; display:inline-block;">View Products →</span>
            </a>
            <a href="/digital-farming" class="info-card" style="text-decoration:none; color:inherit; display:block;">
                <div class="info-card-icon">📱</div>
                <h3>Digital Farming & DripSphere OS™</h3>
                <p>Smart controllers, soil sensors, and the DripSphere OS™ platform — bringing automation, monitoring, and data to your irrigation system.</p>
                <span style="color:var(--blue); font-weight:600; margin-top:12px; display:inline-block;">View Products →</span>
            </a>
        </div>
    </div>
</section>

<!-- Why DripSmart -->
<section class="section" style="background:var(--blue-pale);">
    <div class="container">
        <div class="two-col-layout" style="align-items:center;">
            <div>
                <span class="section-eyebrow">Built Different</span>
                <h2>Why DripSmart Components Perform Longer</h2>
                <div class="benefits-list" style="margin-top:24px;">
                    <div class="benefit-item"><div class="benefit-check">✓</div><div><strong>UV-stabilized materials</strong><p>Every product that sees sunlight is formulated to resist UV degradation — rated for full field-life service even in the California Central Valley.</p></div></div>
                    <div class="benefit-item"><div class="benefit-check">✓</div><div><strong>Clog-resistant turbulent-flow emitters</strong><p>Our emitter flow paths are designed to be self-flushing and resistant to mineral buildup — backed by field data from 10,000+ installations.</p></div></div>
                    <div class="benefit-item"><div class="benefit-check">✓</div><div><strong>Tight manufacturing tolerances</strong><p>Emitter uniformity CV below 3% — meaning every plant in your field gets the same amount of water, regardless of where it sits on the line.</p></div></div>
                    <div class="benefit-item"><div class="benefit-check">✓</div><div><strong>System-engineered compatibility</strong><p>DripSmart fittings, filters, driplines, and controllers are all designed to work together — eliminating compatibility guesswork for your dealer.</p></div></div>
                </div>
            </div>
            <div class="benefit-stat-card" style="align-self:start;">
                <div class="big-stat"><span class="big-number">&lt;3%</span><span class="big-label">Emitter flow CV (coefficient of variation)</span></div>
                <div class="big-stat"><span class="big-number">97%</span><span class="big-label">Distribution uniformity</span></div>
                <div class="big-stat"><span class="big-number">20yr</span><span class="big-label">SDI dripline design life</span></div>
            </div>
        </div>
    </div>
</section>

<!-- Dealer CTA -->
<section class="section" style="background:var(--midnight); color:white;">
    <div class="container text-center">
        <h2 style="color:white;">DripSmart Products Are Sold Through Certified Dealers</h2>
        <p style="color:rgba(255,255,255,0.75); max-width:560px; margin:16px auto 0;">Your local dealer will size, configure, and supply the right products for your operation — backed by on-the-ground expertise that a catalog can't provide.</p>
        <div style="display:flex; gap:16px; justify-content:center; margin-top:32px; flex-wrap:wrap;">
            <a href="/find-a-dealer" class="btn-primary">Find a Dealer Near You</a>
            <a href="/contact" class="btn-outline-white">Dealer Inquiries</a>
        </div>
    </div>
</section>
