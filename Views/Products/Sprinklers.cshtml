@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Sprinklers & Micro-Sprinklers – Drip Smart USA";
    ViewBag.MetaDescription = "DripSmart micro-sprinklers and sprinklers for frost protection, germination, under-canopy irrigation, and high-value crop applications.";
}

<section class="page-hero" style="background: linear-gradient(135deg, #181F4E 0%, #1e2d6e 100%);">
    <div class="container page-hero-inner">
        <div class="page-hero-text">
            <nav class="breadcrumb"><a href="/">Home</a> / <a href="/products">Products</a> / <span>Sprinklers</span></nav>
            <h1>Sprinklers & Micro-Sprinklers</h1>
            <p>Low-volume, high-precision. DripSmart sprinklers deliver targeted water coverage where drip emitters alone aren't enough — frost protection, germination, canopy cooling, and nursery applications.</p>
            <a href="/find-a-dealer" class="btn-primary" style="margin-top:24px;">Find a Local Dealer</a>
        </div>
    </div>
</section>

<!-- Applications -->
<section class="section">
    <div class="container">
        <div class="section-header centered">
            <span class="section-eyebrow">Where They Shine</span>
            <h2>Purpose-Built for Demanding Applications</h2>
        </div>
        <div class="two-col-layout" style="margin-top:40px; gap:24px;">
            <div class="info-card">
                <div class="info-card-icon"><i data-lucide="snowflake"></i></div>
                <h3>Frost Protection</h3>
                <p>Micro-sprinklers under tree canopies form a protective ice layer around blossoms during freeze events — protecting your investment without over-applying water. Widely used in citrus, almonds, and stone fruit.</p>
            </div>
            <div class="info-card">
                <div class="info-card-icon"><i data-lucide="sprout"></i></div>
                <h3>Germination & Establishment</h3>
                <p>Fine-mist and gentle-spray heads keep seed beds uniformly moist during germination — critical for small-seeded crops where inconsistent moisture causes stand failures.</p>
            </div>
            <div class="info-card">
                <div class="info-card-icon"><i data-lucide="home"></i></div>
                <h3>Nursery & Container Crops</h3>
                <p>Overhead and under-bench micro-sprinklers provide uniform wetting for potted plants and propagation beds — programmable to match container size and plant species.</p>
            </div>
            <div class="info-card">
                <div class="info-card-icon"><i data-lucide="tree-pine"></i></div>
                <h3>Young Tree Establishment</h3>
                <p>Spinners and bubblers deliver a larger wetting pattern around newly planted trees — speeding establishment and reducing transplant stress in the first season.</p>
            </div>
        </div>
    </div>
</section>

<!-- Product Types -->
<section class="section" style="background:var(--blue-pale);">
    <div class="container">
        <div class="section-header centered">
            <span class="section-eyebrow">Product Lines</span>
            <h2>Sprinkler Types & Configurations</h2>
        </div>
        <div class="three-col-grid" style="margin-top:40px;">
            <div class="info-card">
                <div class="info-card-icon"><i data-lucide="wind"></i></div>
                <h3>Micro-Spinners</h3>
                <p>Rotating head sprinklers with 4–15 ft throw radius. Low application rate prevents runoff and provides even coverage. Available in full- and part-circle patterns.</p>
                <ul class="check-list" style="margin-top:12px;">
                    <li>5–50 GPH flow rates</li>
                    <li>Pressure-compensating models</li>
                    <li>Barb or threaded connection</li>
                </ul>
            </div>
            <div class="info-card">
                <div class="info-card-icon"><i data-lucide="droplets"></i></div>
                <h3>Micro-Jets</h3>
                <p>Fixed-pattern jets for uniform wetting in tight spaces. Ideal for under-bench nursery use and groundcover establishment where spinner turbulence is undesirable.</p>
                <ul class="check-list" style="margin-top:12px;">
                    <li>2–8 ft throw radius</li>
                    <li>360°, 180°, and 90° patterns</li>
                    <li>Color-coded by flow rate</li>
                </ul>
            </div>
            <div class="info-card">
                <div class="info-card-icon"><i data-lucide="circle-dot"></i></div>
                <h3>Bubblers & Soakers</h3>
                <p>Low-flow bubblers flood a small area around individual trees or shrubs. Zero throw — all water goes directly to the root zone. Zero drift, no wetting of foliage.</p>
                <ul class="check-list" style="margin-top:12px;">
                    <li>0.5–2.0 GPH flow rates</li>
                    <li>Adjustable and preset options</li>
                    <li>Ideal for tree establishment</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="section" style="background:var(--midnight); color:white;">
    <div class="container text-center">
        <h2 style="color:white;">Need Help Choosing the Right Head?</h2>
        <p style="color:rgba(255,255,255,0.75); max-width:520px; margin:16px auto 0;">Sprinkler selection depends on throw radius, application rate, pressure, and crop. Your local DripSmart dealer will spec the right product for your application.</p>
        <a href="/find-a-dealer" class="btn-primary" style="margin-top:28px; display:inline-block;">Find a Local Dealer</a>
    </div>
</section>
