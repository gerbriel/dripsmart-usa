@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Driplines & Drip Tape – Drip Smart USA";
    ViewBag.MetaDescription = "DripSmart driplines and drip tape for row crops, orchards, vineyards, and subsurface irrigation. Pressure-compensating and standard emitter options.";
}

<section class="page-hero" style="background: linear-gradient(135deg, #181F4E 0%, #1e2d6e 100%);">
    <div class="container page-hero-inner">
        <div class="page-hero-text">
            <nav class="breadcrumb"><a href="/">Home</a> / <a href="/products">Products</a> / <span>Driplines & Drip Tape</span></nav>
            <h1>Driplines & Drip Tape</h1>
            <p>The core of every drip irrigation system. DripSmart driplines and tape are engineered for uniform delivery, long service life, and compatibility across our full product ecosystem.</p>
            <a href="/find-a-dealer" class="btn-primary" style="margin-top:24px;">Get Dealer Pricing</a>
        </div>
    </div>
</section>

<!-- Product Families -->
<section class="section">
    <div class="container">
        <div class="section-header centered">
            <span class="section-eyebrow">Product Families</span>
            <h2>Choose the Right Line for Your Crop</h2>
        </div>
        <div class="three-col-grid" style="margin-top:40px;">
            <div class="info-card">
                <div class="info-card-icon"><i data-lucide="minus-circle"></i></div>
                <h3>DS-Tape™ (Drip Tape)</h3>
                <p>Thin-wall, flat-emitter drip tape for annual crops. Designed for seasonal installation and removal. Available in multiple wall thicknesses for 1-, 2-, or 3-season use.</p>
                <ul class="check-list" style="margin-top:16px;">
                    <li>5/8" diameter standard</li>
                    <li>4"–24" emitter spacing</li>
                    <li>0.15–0.45 GPM/100ft flow rates</li>
                    <li>4 mil, 6 mil, 8 mil wall options</li>
                </ul>
                <p style="font-size:0.82rem; color:var(--text-muted); margin-top:12px;"><strong>Best for:</strong> Cotton, corn, tomatoes, melons, lettuce, small grains</p>
            </div>
            <div class="info-card">
                <div class="info-card-icon"><i data-lucide="minus-circle"></i></div>
                <h3>DS-Line PC™ (Pressure Compensating)</h3>
                <p>Thick-wall dripline with pressure-compensating emitters. Maintains uniform flow across pressure variation — ideal for slopes and long run lengths.</p>
                <ul class="check-list" style="margin-top:16px;">
                    <li>0.5, 1.0, and 2.0 GPH emitter rates</li>
                    <li>12"–60" emitter spacing</li>
                    <li>Anti-drain and self-flush versions</li>
                    <li>UV-stabilized for surface use</li>
                </ul>
                <p style="font-size:0.82rem; color:var(--text-muted); margin-top:12px;"><strong>Best for:</strong> Almonds, citrus, grapes, avocados, hill country orchards</p>
            </div>
            <div class="info-card">
                <div class="info-card-icon"><i data-lucide="minus-circle"></i></div>
                <h3>DS-Sub™ (Subsurface SDI)</h3>
                <p>Premium thick-wall dripline engineered for permanent subsurface installation. Root-barrier treated and built for 15–20 year service life underground.</p>
                <ul class="check-list" style="margin-top:16px;">
                    <li>Copper-based root inhibitor treatment</li>
                    <li>Check-valve emitters prevent backflow</li>
                    <li>Rated for 6"–18" burial depth</li>
                    <li>Compatible with standard fittings</li>
                </ul>
                <p style="font-size:0.82rem; color:var(--text-muted); margin-top:12px;"><strong>Best for:</strong> Alfalfa, permanent row crops, SDI field corn</p>
            </div>
        </div>
    </div>
</section>

