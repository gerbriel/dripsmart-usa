@{
    ViewBag.Title = "Find a Dealer – Drip Smart USA";
    ViewBag.MetaDescription = "Locate your nearest DripSmart certified irrigation dealer. Get local product expertise, system design, and installation support wherever you farm or grow.";
}

<!-- Hero -->
<section class="page-hero bg-midnight section">
    <div class="container">
        <div class="page-hero-inner">
            <div class="breadcrumb"><a href="/">Home</a> › <span>Find a Dealer</span></div>
            <div class="page-hero-text">
                <span class="section-eyebrow">Dealer Network</span>
                <h1>Find a DripSmart<br>Dealer Near You.</h1>
                <p>Over 1,200 certified dealers across the United States carry DripSmart products and provide local system design, installation, and service. Get the hardware you need, backed by someone who knows your region.</p>
            </div>
        </div>
    </div>
</section>

<!-- Search + Results -->
<section class="section bg-cream">
    <div class="container">
        <div class="two-col-layout" style="align-items: flex-start;">
            <!-- Search Panel -->
            <div>
                <div class="dealer-form">
                    <h3>Search Dealers</h3>
                    <div class="form-group">
                        <label for="search-zip">ZIP Code or City</label>
                        <input type="text" id="search-zip" placeholder="e.g. Fresno, CA or 93710" />
                    </div>
                    <div class="form-group">
                        <label for="search-industry">Industry / Application</label>
                        <select id="search-industry">
                            <option value="">All Industries</option>
                            <option>Agriculture</option>
                            <option>Landscape &amp; Turf</option>
                            <option>Greenhouse &amp; Nursery</option>
                            <option>Golf &amp; Sports Turf</option>
                            <option>Wastewater</option>
                            <option>Mining</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="search-radius">Search Radius</label>
                        <select id="search-radius">
                            <option>25 miles</option>
                            <option selected>50 miles</option>
                            <option>100 miles</option>
                            <option>250 miles</option>
                            <option>Nationwide</option>
                        </select>
                    </div>
                    <button class="btn-primary btn-full">Search Dealers</button>
                </div>

                <!-- Become a Dealer -->
                <div class="info-card" style="margin-top: 20px; background: var(--midnight); border-color: transparent;">
                    <h3 style="color: var(--white);">Become a DripSmart Dealer</h3>
                    <p style="color: rgba(255,255,255,0.6); margin-bottom: 16px;">Join our network of 1,200+ dealers. Get exclusive pricing, training, co-op marketing funds, and technical support.</p>
                    <a href="/contact" class="btn-outline-white">Apply to Join</a>
                </div>
            </div>

            <!-- Results list -->
            <div>
                <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 8px;">Showing featured dealers — search above for dealers near you</p>
