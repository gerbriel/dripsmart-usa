@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Digital Farming & DripSphere OS™ – Drip Smart USA";
}

<section class="page-hero" style="background: linear-gradient(135deg, #012a14 0%, #0d5c36 100%);">
    <div class="container page-hero-inner">
        <div class="page-hero-text">
            <nav class="breadcrumb"><a href="/">Home</a> / <span>Digital Farming</span></nav>
            <div class="hero-eyebrow"><span class="badge badge-green">New Platform</span></div>
            <h1>Control Your Whole Farm<br/>From One App</h1>
            <p>DripSphere OS™ is our smart irrigation and fertigation platform — real-time visibility and full control over every zone, every crop, anywhere you are.</p>
            <div class="hero-actions">
                <a href="/contact" class="btn-primary btn-lg">Request a Demo</a>
                <a href="/agriculture/precision-irrigation" class="btn-ghost btn-lg">Learn More</a>
            </div>
        </div>
    </div>
</section>

<!-- App Features -->
<section class="section">
    <div class="container">
        <div class="digital-layout">
            <div class="digital-visual">
                <div class="app-mockup">
                    <div class="app-header">
                        <span class="app-logo">DripSphere OS™</span>
                        <span class="app-status badge-sm badge-green">● Live</span>
                    </div>
                    <div class="app-field-map">
                        <div class="field-zone active">Zone A<br/><small>💧 Irrigating</small></div>
                        <div class="field-zone">Zone B<br/><small>✓ Optimal</small></div>
                        <div class="field-zone">Zone C<br/><small>✓ Optimal</small></div>
                        <div class="field-zone scheduled">Zone D<br/><small>⏰ Scheduled</small></div>
                    </div>
                    <div class="app-metrics">
                        <div class="app-metric"><span class="metric-icon">🌡️</span><div><div class="metric-val">72°F</div><div class="metric-lbl">Air Temp</div></div></div>
                        <div class="app-metric"><span class="metric-icon">💧</span><div><div class="metric-val">68%</div><div class="metric-lbl">Soil Moisture</div></div></div>
                        <div class="app-metric"><span class="metric-icon">⚡</span><div><div class="metric-val">12 gph</div><div class="metric-lbl">Flow Rate</div></div></div>
                    </div>
                </div>
            </div>
            <div class="digital-text">
                <span class="section-eyebrow">Platform Features</span>
                <h2>Everything You Need in One Dashboard</h2>
                <ul class="feature-list">
                    <li><div class="feature-icon">📊</div><div><strong>Real-time soil moisture & weather data</strong><br/>Make data-driven irrigation decisions — not guesswork.</div></li>
                    <li><div class="feature-icon">⚙️</div><div><strong>Automated scheduling & smart alerts</strong><br/>Set rules, get notified, and never over- or under-water again.</div></li>
                    <li><div class="feature-icon">🧪</div><div><strong>Precision fertigation control</strong><br/>Deliver the right nutrients at the right dose and time.</div></li>
                    <li><div class="feature-icon">📱</div><div><strong>Works on any device</strong><br/>iOS, Android, or desktop — your farm data is always accessible.</div></li>
                    <li><div class="feature-icon">📈</div><div><strong>Season-over-season analytics</strong><br/>Track water use, yield trends, and ROI across your entire operation.</div></li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Fertigation -->
<section class="section" style="background:var(--green-pale);">
    <div class="container">
        <div class="two-col-layout">
            <div>
                <span class="section-eyebrow">Precision Fertigation</span>
                <h2>Feed Your Crops Smarter</h2>
                <p>Fertigation — delivering fertilizer through your irrigation system — is the most efficient way to feed crops. DripSphere OS™ automates it completely.</p>
                <div class="benefits-list" style="margin-top:24px;">
                    <div class="benefit-item"><div class="benefit-check">✓</div><div><strong>20–40% fertilizer savings</strong><p>Nutrients applied in small, frequent doses are absorbed more efficiently with zero runoff.</p></div></div>
                    <div class="benefit-item"><div class="benefit-check">✓</div><div><strong>Crop-stage aware dosing</strong><p>Adjust nutrient ratios automatically based on the plant's growth stage.</p></div></div>
                    <div class="benefit-item"><div class="benefit-check">✓</div><div><strong>Full audit trail</strong><p>Track every application for compliance, recordkeeping, and optimization.</p></div></div>
                </div>
            </div>
            <div class="info-card" style="align-self:start;">
                <div class="info-card-icon">🧪</div>
                <h3>Netaflex™ 5G Fertigation Unit</h3>
                <p style="margin-top:8px; font-size:0.9rem;">Our flagship fertigation controller, powered by DripSphere OS™. Delivers unrivalled uniformity across large multi-zone operations.</p>
                <a href="/contact" class="btn-primary" style="margin-top:20px; display:inline-flex;">Request a Demo</a>
            </div>
        </div>
    </div>
</section>
