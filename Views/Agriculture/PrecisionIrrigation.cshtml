@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Precision Irrigation – Drip Smart USA";
}

<section class="page-hero" style="background: linear-gradient(135deg, #0e1438 0%, #181F4E 100%);">
    <div class="container page-hero-inner">
        <div class="page-hero-text">
            <nav class="breadcrumb"><a href="/">Home</a> / <a href="/agriculture">Agriculture</a> / <span>Precision Irrigation</span></nav>
            <h1>What Is Precision Irrigation?</h1>
            <p>An approach that delivers the right amount of water and nutrients to each plant, at exactly the right time — eliminating waste and maximizing growth.</p>
        </div>
    </div>
</section>

<!-- Definition -->
<section class="section">
    <div class="container">
        <div class="two-col-layout">
            <div>
                <span class="section-eyebrow">The Science</span>
                <h2>Root-Zone Delivery, Zero Waste</h2>
                <p>Traditional irrigation floods or sprays water broadly — much of it evaporates, runs off, or never reaches the root zone. Precision drip irrigation changes this entirely.</p>
                <p style="margin-top:14px;">Emitters placed at or below the soil surface release tiny, measured amounts of water directly to each plant's roots. The result: crops always have exactly what they need, and nothing is wasted.</p>
                <div class="benefits-list" style="margin-top:28px;">
                    <div class="benefit-item"><div class="benefit-check">✓</div><div><strong>Right time</strong><p>Irrigation is triggered by soil moisture sensors and crop demand, not a fixed schedule.</p></div></div>
                    <div class="benefit-item"><div class="benefit-check">✓</div><div><strong>Right place</strong><p>Water goes directly to the root zone — not the soil surface, the weeds, or the air.</p></div></div>
                    <div class="benefit-item"><div class="benefit-check">✓</div><div><strong>Right amount</strong><p>Small, frequent doses maintain optimal soil moisture — no over- or under-watering.</p></div></div>
                </div>
            </div>
            <div class="benefit-stat-card" style="align-self:start;">
                <div class="big-stat"><span class="big-number">50%</span><span class="big-label">Less Water Used</span></div>
                <div class="big-stat"><span class="big-number">30%</span><span class="big-label">Higher Yields</span></div>
                <div class="big-stat"><span class="big-number">40%</span><span class="big-label">Fertilizer Savings</span></div>
                <div class="big-stat"><span class="big-number">100%</span><span class="big-label">Customizable</span></div>
            </div>
        </div>
    </div>
</section>

