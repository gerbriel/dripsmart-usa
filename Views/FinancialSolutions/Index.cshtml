@{
    ViewBag.Title = "Financial Solutions – Drip Smart USA";
    ViewBag.MetaDescription = "Flexible financing options for drip irrigation systems. 0% interest programs, USDA-backed loans, leasing, and FSA-compatible payment plans for farmers of all sizes.";
}

<!-- Hero -->
<section class="page-hero bg-midnight section">
    <div class="container">
        <div class="page-hero-inner">
            <div class="breadcrumb"><a href="/">Home</a> › <span>Financial Solutions</span></div>
            <div class="page-hero-text">
                <span class="section-eyebrow">Financial Solutions</span>
                <h1>Invest in Efficiency.<br>We'll Help You Get There.</h1>
                <p>A DripSmart system typically pays for itself in 2–4 seasons through water savings, yield improvements, and reduced labor. We offer multiple financing paths to make the investment accessible — right now.</p>
                <div class="hero-actions">
                    <a href="/contact" class="btn-primary btn-lg">Talk to a Financing Specialist</a>
                    <a href="#programs" class="btn-ghost">See Financing Options</a>
                </div>
            </div>
        </div>
        <div class="crop-hero-stats">
            <div class="crop-stat"><span class="crop-stat-num">2–4</span><span class="crop-stat-label">Yr Average Payback</span></div>
            <div class="crop-stat"><span class="crop-stat-num">0%</span><span class="crop-stat-label">Interest — 12 Months</span></div>
            <div class="crop-stat"><span class="crop-stat-num">$5K+</span><span class="crop-stat-label">Avg. Annual Water Savings</span></div>
            <div class="crop-stat"><span class="crop-stat-num">USDA</span><span class="crop-stat-label">EQIP Compatible</span></div>
        </div>
    </div>
</section>

<!-- Financing Programs -->
<section class="section bg-cream" id="programs">
    <div class="container">
        <div class="section-header centered">
            <span class="section-eyebrow">Financing Programs</span>
            <h2>Choose the Plan That Fits Your Operation</h2>
            <p>Whether you're a small family farm or a large commercial grower, we have a financing structure built for you.</p>
        </div>
        <div class="pricing-grid">
            <div class="pricing-card">
                <h3>DripSmart Easy Start</h3>
                <div class="price">0% <span>for 12 months</span></div>
                <p>Zero-interest financing through our dealer network for system purchases $5,000–$50,000. No prepayment penalty.</p>
                <ul class="check-list">
                    <li>Instant approval, 5-minute application</li>
                    <li>Available through certified dealers</li>
                    <li>Minimum purchase: $5,000</li>
                    <li>Deferred to 0% for 12 months</li>
                    <li>Standard rates apply after 12 months</li>
                </ul>
                <a href="/contact" class="btn-primary btn-full" style="margin-top:24px;">Apply Now</a>
            </div>
            <div class="pricing-card featured">
                <span class="pricing-card-badge">Most Popular</span>
                <h3>Farm Advantage Loan</h3>
                <div class="price">2.9% <span>APR / 60-month term</span></div>
                <p>Our flagship farm financing program for full-system installations. Low fixed rates, long terms, and tailored to ag cash flow.</p>
                <ul class="check-list">
                    <li>2.9% fixed APR for qualified borrowers</li>
                    <li>Terms up to 84 months</li>
                    <li>Seasonal payment schedules available</li>
                    <li>Covers equipment + installation</li>
                    <li>USDA EQIP cost-share compatible</li>
                </ul>
                <a href="/contact" class="btn-primary btn-full" style="margin-top:24px;">Get Pre-Qualified</a>
            </div>
            <div class="pricing-card">
                <h3>Equipment Lease</h3>
                <div class="price">$1 <span>buyout at lease end</span></div>
                <p>Keep capital off your balance sheet and preserve borrowing capacity with a full-system operating or capital lease.</p>
                <ul class="check-list">
                    <li>Monthly payments starting under $200</li>
                    <li>Operating or capital lease options</li>
                    <li>Section 179 tax deduction eligible</li>
                    <li>Upgrade option at lease end</li>
                    <li>Available for systems $10,000+</li>
                </ul>
                <a href="/contact" class="btn-primary btn-full" style="margin-top:24px;">Get a Lease Quote</a>
            </div>
        </div>
    </div>
</section>

<!-- Government programs -->
<section class="section">
    <div class="container">
        <div class="section-header centered">
            <span class="section-eyebrow">Government Programs</span>
            <h2>Maximize Your USDA &amp; State Incentives</h2>
            <p>Most DripSmart irrigation systems qualify for federal and state cost-share and incentive programs that can cover 40–75% of your system cost.</p>
        </div>
        <div class="three-col-grid">
            <div class="info-card">
                <div class="info-card-icon">🏛️</div>
                <h3>USDA EQIP</h3>
                <p>The USDA Environmental Quality Incentives Program (EQIP) provides payments for conservation practices including irrigation system upgrades. Drip irrigation typically qualifies for Practice Standard 441.</p>
                <ul class="check-list">
                    <li>Up to $450,000 in EQIP payments</li>
                    <li>5-year conservation plan required</li>
                    <li>We assist with application paperwork</li>
                </ul>
                <a href="/contact" class="btn-primary-sm mt-md" style="margin-top:16px;">EQIP Consultation</a>
            </div>
            <div class="info-card">
                <div class="info-card-icon">💧</div>
                <h3>State Water Districts</h3>
                <p>Many state and local irrigation districts offer rebates for converting from flood or sprinkler to drip irrigation. Average rebates range from $200–$1,200 per acre.</p>
                <ul class="check-list">
                    <li>DripSmart can identify your local programs</li>
                    <li>We provide required installation documentation</li>
                    <li>Rebates paid after system installation</li>
                </ul>
                <a href="/contact" class="btn-primary-sm mt-md" style="margin-top:16px;">Find My Rebates</a>
            </div>
            <div class="info-card">
                <div class="info-card-icon">⚡</div>
                <h3>Utility Energy Rebates</h3>
                <p>Drip irrigation reduces pumping energy requirements by 30–60%. Many electric utilities offer pump efficiency rebates that stack with EQIP and district programs.</p>
                <ul class="check-list">
                    <li>Average utility rebate: $500–$3,000</li>
                    <li>Efficiency verification report included</li>
                    <li>Compatible with solar pump systems</li>
                </ul>
                <a href="/contact" class="btn-primary-sm mt-md" style="margin-top:16px;">Estimate My Rebates</a>
            </div>
        </div>
    </div>
</section>

<!-- ROI calculator callout -->
<section class="section bg-blue-pale">
    <div class="container">
        <div class="two-col-layout">
            <div>
                <span class="section-eyebrow">Return on Investment</span>
                <h2>What's the Real Cost of Waiting?</h2>
                <p>Every season you delay switching to drip irrigation is money left on the table. Here's what a typical 100-acre almond grower saves in Year 1:</p>
                <div style="margin-top: 28px; display: flex; flex-direction: column; gap: 16px;">
                    <div style="display:flex;justify-content:space-between;align-items:center;padding:16px;background:var(--white);border-radius:10px;border:1.5px solid var(--border);">
                        <span style="font-weight:600;color:var(--midnight);">Water Cost Savings</span>
                        <span style="font-size:1.25rem;font-weight:800;color:var(--blue);">+$8,200</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;padding:16px;background:var(--white);border-radius:10px;border:1.5px solid var(--border);">
                        <span style="font-weight:600;color:var(--midnight);">Pumping Energy Savings</span>
                        <span style="font-size:1.25rem;font-weight:800;color:var(--blue);">+$3,100</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;padding:16px;background:var(--white);border-radius:10px;border:1.5px solid var(--border);">
                        <span style="font-weight:600;color:var(--midnight);">Labor Reduction</span>
                        <span style="font-size:1.25rem;font-weight:800;color:var(--blue);">+$4,800</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;padding:16px;background:var(--white);border-radius:10px;border:1.5px solid var(--border);">
                        <span style="font-weight:600;color:var(--midnight);">Yield Improvement (est.)</span>
                        <span style="font-size:1.25rem;font-weight:800;color:var(--green-02);">+$12,500</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;padding:20px;background:var(--midnight);border-radius:10px;">
                        <span style="font-weight:700;color:var(--white);">Total Year-1 Benefit</span>
                        <span style="font-size:1.5rem;font-weight:800;color:var(--mustard);">$28,600</span>
                    </div>
                </div>
            </div>
            <div>
                <div class="dealer-form">
                    <h3>Calculate Your ROI</h3>
                    <div class="form-group">
                        <label>Irrigated Acres</label>
                        <input type="number" placeholder="e.g. 150" />
                    </div>
                    <div class="form-group">
                        <label>Current Irrigation Method</label>
                        <select>
                            <option>Flood / Furrow</option>
                            <option>Center Pivot Sprinkler</option>
                            <option>Solid Set Sprinkler</option>
                            <option>Wheel Line Sprinkler</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Primary Crop</label>
                        <select>
                            <option>Almonds</option>
                            <option>Citrus</option>
                            <option>Cotton</option>
                            <option>Corn</option>
                            <option>Soybeans</option>
                            <option>Strawberries</option>
                            <option>Wine Grapes</option>
                            <option>Alfalfa</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Current Water Cost ($/acre-foot)</label>
                        <input type="number" placeholder="e.g. 185" />
                    </div>
                    <button class="btn-primary btn-full">Calculate My Savings</button>
                    <p style="font-size:0.78rem;color:var(--text-muted);margin-top:10px;text-align:center;">Or <a href="/contact" style="color:var(--blue);">speak to a specialist</a> for a detailed analysis</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<div class="callout-band">
    <div class="container">
        <h2>Ready to Find the Right Financing?</h2>
        <p>Our financing specialists will help you combine programs to minimize your out-of-pocket cost and maximize your ROI.</p>
        <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
            <a href="/contact" class="btn-white">Talk to a Financing Specialist</a>
            <a href="/contact" class="btn-outline-white">Request a Custom Quote</a>
        </div>
    </div>
</div>
