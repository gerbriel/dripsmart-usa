    <div class="container" style="max-width:640px;">
        <h2>Want Results Like These on Your Farm?</h2>
        <p style="margin:14px 0 32px;">See the product specs and performance data for your crop, then connect with a certified dealer near you to get started.</p>
        <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
            <a href="/agriculture/crops" class="btn-primary btn-lg">Explore Crop Solutions</a>
            <a href="/find-a-dealer" class="btn-outline">Find a Dealer</a>
        </div>
    </div>
</section>
